# Slack (Socket Mode recommended for local / standalone)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Jira Cloud (basic auth: email + API token)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=FILING

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: if you need to match bot user in mention parsing before auth.test wiring
# SLACK_BOT_USER_ID=U01234567
